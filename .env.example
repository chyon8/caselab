# CaseLab 자체 DB (Neon). 없으면 mock 어댑터로 동작한다.
DATABASE_URL=

# mock | postgres — 화면이 어느 어댑터를 바라볼지
CASELAB_DATA_SOURCE=mock

# n8n → /api/sync/* 호출 시 X-CaseLab-Key 헤더로 보내는 시크릿
CASELAB_SYNC_KEY=

# 홈 "지금 동기화" 버튼이 칠 n8n Webhook 노드의 Production URL (…/webhook/… , test 아님)
# 커스텀 path(wishket-sync-trigger)로 등록 — 구 UUID path 는 Cloudflare Access 에 막혀 Vercel 502.
# 로컬(.env.local)과 Vercel 대시보드에 같은 값을 넣고, Vercel 은 저장 후 재배포해야 반영된다.
N8N_SYNC_WEBHOOK_URL=
